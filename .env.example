# ---- App ----
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480
BACKEND_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

# Ngrok (optional, for exposing Twilio webhooks during local dev)
NGROK_ENABLED=false
NGROK_AUTHTOKEN=

# ---- Pipeline thresholds ----
# Resume score (0-100) >= threshold -> screening; else rejected.
RESUME_SCORE_THRESHOLD=70
# Screening call score (0-100) >= threshold -> ready for scheduling.
CALL_SCORE_THRESHOLD=70
GMAIL_POLL_INTERVAL_MINUTES=5
# Auto-email new email applicants for the logistics fields missing from their
# resume (CTC, notice period, availability, shift/work-mode) and parse replies.
DETAIL_COLLECTION_ENABLED=true

# ---- Interview feedback collection (Teams + email) ----
# Master switch for the post-interview feedback workflow: detect concluded
# interviews, email the interviewer for feedback, monitor the domain Teams
# channel + email replies, AI-extract feedback, remind (24h/48h) and escalate (72h).
FEEDBACK_COLLECTION_ENABLED=true
FEEDBACK_POLL_INTERVAL_MINUTES=5
# Minutes after scheduled_at before an interview is assumed concluded.
INTERVIEW_COMPLETION_BUFFER_MINUTES=30
# Auto-advance the application from the extracted recommendation (NO -> REJECTED,
# strong-yes on a final round -> OFFERED). false keeps it record-only.
FEEDBACK_AUTO_ADVANCE_ENABLED=true
# Min LLM confidence (0-1) to accept a Teams message as feedback for a candidate.
FEEDBACK_MATCH_MIN_CONFIDENCE=0.6
# Optional override for the 72h escalation recipient; blank -> requisition hiring
# manager (fallback: the interview creator).
FEEDBACK_ESCALATION_EMAIL=

# ---- Database (local Docker Postgres on host port 5434) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_DB=recruitment
POSTGRES_USER=recruitment
POSTGRES_PASSWORD=recruitment

# ---- Encryption (AES-256-GCM for phone / current_ctc / expected_ctc at rest) ----
# Generate: python -c "import os,base64;print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=

# ---- LLM (provider-agnostic via LangChain) ----
# If ANTHROPIC_API_KEY is set, Claude is used; otherwise OpenAI is used.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Gmail (resume auto-ingestion) ----
# Path A — Google Workspace service account (most durable; no refresh token).
# GOOGLE_SERVICE_ACCOUNT_JSON may be a path to the key file OR the inline JSON.
# GMAIL_IMPERSONATE_EMAIL is the Workspace mailbox to read (domain-wide delegation).
GOOGLE_SERVICE_ACCOUNT_JSON=
GMAIL_IMPERSONATE_EMAIL=
# Path B — OAuth web client. Set CLIENT_ID/SECRET, then connect once via the
# admin UI (Admin → Integrations → Connect Gmail); the refresh token is stored
# encrypted in the DB. No need to paste a refresh token here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Legacy/optional: a static refresh token fallback for the OAuth client above.
# Prefer the admin Connect flow (Path B) so tokens are managed in the DB.
GOOGLE_REFRESH_TOKEN=

# ---- Microsoft Graph (interview scheduling / Teams) ----
# App-only (client-credentials) auth. Scheduling needs Calendars.ReadWrite +
# OnlineMeetings.ReadWrite. Reading Teams hiring-channel messages for feedback
# additionally needs the ChannelMessage.Read.All APPLICATION permission with
# admin consent (a Microsoft "protected"/metered Graph API). Without it the Teams
# monitor logs a warning and degrades to skip — email feedback still works.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# ---- Twilio (telephonic screening) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ---- Screening voice agent (conversational call) ----
# Company the agent says it's calling from, in the intro.
COMPANY_NAME=Intelera
# Optional caller persona name ("this is <name> calling from <company>"); blank → "the talent team".
SCREENING_AGENT_NAME=
# Twilio <Say> voice — Amazon Polly Indian-English neural by default.
TTS_VOICE=Polly.Kajal-Neural
# Speech-recognition language hint for Twilio <Gather input="speech">.
STT_LANGUAGE=en-IN

# ---- Realtime voice streaming (low-latency speech-to-speech) ----
# true → screening calls stream audio (Twilio Media Streams <-> OpenAI Realtime)
# with a parallel Deepgram transcript tap. false → legacy <Gather>/<Say> IVR.
VOICE_STREAMING_ENABLED=true
# Realtime model (GA): gpt-realtime (best) or gpt-realtime-mini (cheaper/faster).
# Note: *-realtime-preview models are disabled (beta_api_shape_disabled).
OPENAI_REALTIME_MODEL=gpt-realtime
# Realtime voice (not a Polly voice): alloy, echo, shimmer, marin, cedar, …
REALTIME_VOICE=alloy
# server_vad end-of-speech window (ms); lower = snappier but more false barge-ins.
REALTIME_SILENCE_MS=320

# ---- Deepgram (speech-to-text) ----
DEEPGRAM_API_KEY=
# Streaming model for the live transcript tap (nova-2 proven for en-IN; nova-3 more accurate).
DEEPGRAM_LIVE_MODEL=nova-2
